{
  "name": "@mr_ozio/scraper-utils",
  "version": "2.2.0",
  "description": "Small utilities. Named APIs. Pleasant call sites.",
  "type": "module",
  "main": "./index.mjs",
  "exports": {
    ".": "./index.mjs",
    "./package.json": "./package.json",
    "./classes/*": "./classes/*.mjs",
    "./classes/*.mjs": "./classes/*.mjs",
    "./constants/*": "./constants/*.mjs",
    "./constants/*.mjs": "./constants/*.mjs",
    "./formatters/*": "./formatters/*.mjs",
    "./formatters/*.mjs": "./formatters/*.mjs",
    "./fs/*": "./fs/*.mjs",
    "./fs/*.mjs": "./fs/*.mjs",
    "./helpers/*": "./helpers/*.mjs",
    "./helpers/*.mjs": "./helpers/*.mjs",
    "./network/*": "./network/*.mjs",
    "./network/*.mjs": "./network/*.mjs",
    "./printers/*": "./printers/*.mjs",
    "./printers/*.mjs": "./printers/*.mjs",
    "./validators/*": "./validators/*.mjs",
    "./validators/*.mjs": "./validators/*.mjs"
  },
  "files": [
    "index.mjs",
    "classes",
    "constants",
    "formatters",
    "fs",
    "helpers",
    "jsons",
    "network",
    "printers",
    "validators"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozio/scraper-utils.git"
  },
  "bugs": {
    "url": "https://github.com/ozio/scraper-utils/issues"
  },
  "homepage": "https://github.com/ozio/scraper-utils#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "docs:build": "node scripts/generate-docs.mjs",
    "format": "prettier --write .",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "prepublishOnly": "bun test && npm run pack:check",
    "release:publish": "node scripts/publish-package.mjs",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "keywords": [
    "scraper",
    "utilities",
    "helpers",
    "filesystem",
    "formatting",
    "queue"
  ],
  "dependencies": {
    "abort-controller": "3.0.0",
    "ansi-html": "0.0.9",
    "chalk": "5.0.1",
    "color-hash": "2.0.1",
    "dotenv": "16.0.0",
    "ffprobe-client": "1.1.6",
    "iconv": "3.0.1",
    "imghash": "0.0.9",
    "linkify-html": "3.0.5",
    "nilsimsa": "^0.2.7",
    "node-fetch": "3.2.10",
    "node-html-parser": "5.3.3",
    "nodemailer": "6.7.5",
    "progress-stream": "2.0.0",
    "sharp": "0.32.1",
    "socks-proxy-agent": "6.2.0-beta.0"
  },
  "devDependencies": {
    "prettier": "2.6.2"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "embeddedLanguageFormatting": "auto",
    "endOfLine": "lf",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "printWidth": 120,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "requirePragma": false,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
